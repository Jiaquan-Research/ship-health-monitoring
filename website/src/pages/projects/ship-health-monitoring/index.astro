  <PageHero eyebrow="Project" title="Ship Health Monitoring" summary="A traceable research and governance package for future Marine validation preparation." />
  <AuthorityBanner ids={["MPV1-PACKAGE", "ROOT-SYSTEM-STATE"]} />
  <StatusGrid />
  <RelatedPages links={[
    { label: "Marine Package", href: "/projects/ship-health-monitoring/marine-package", text: "Frozen package and documented gaps." },
    { label: "Evidence Boundaries", href: "/projects/ship-health-monitoring/boundaries", text: "Claims, gaps, evidence limits, and prohibited overclaims." },
    { label: "External Validation", href: "/projects/ship-health-monitoring/external-validation", text: "Frozen human-reviewer definition; execution not started." },
    { label: "Deep Research", href: "/projects/ship-health-monitoring/deep-research", text: "Advisory blind-review interface and execution package." },
    { label: "Framework", href: "/projects/ship-health-monitoring/framework", text: "Health Evidence architecture and decision documents." },
    { label: "Validation", href: "/projects/ship-health-monitoring/validation", text: "Public-data validation roles." }
  ]} />
